#include "main.h"

/**
 *jack_bauer - bsolute value of a number
 *
 *Description : /
 *Return: absolute value of n
 */

void times_table(void)
{
	int a;
	int b;
	int result;
	for (a = 0; a >= 9; a++)
    {
		for (b = 0; b >= 9; b++)
	    {
			result = a * b;
			if (result >= 10)
		    {
				_putchar(result / 10 + '0');
				_putchar(result % 10 + '0');
		    }
			else
			{
				_putchar(result + '0');
		    }
		}
    }
}	
