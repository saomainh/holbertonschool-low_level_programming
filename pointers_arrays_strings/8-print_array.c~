void print_array(int *a, int n)
{
	int i;
	int element;

	for (i = 0; i < n; i++)
	{
		element = a[i];
		printf("%d", element);
		if (i != n - 1)
	    {
			printf(", ");
		}
	}
	printf("\n");
}
