/**
 *_memset - finds the lenght of a string
 *@s : eafear
 *@b : fezfz
 *@n : ezfze
 *Description : /
 *Return: count
 */

char *_memset(char *s, char b, unsigned int n)
{
	unsigned int i;

	for (i = 0; i < n; i++)
	{
		s[i] = b;
	}
	return (s);
}
