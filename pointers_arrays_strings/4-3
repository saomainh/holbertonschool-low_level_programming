#include "stddef.h"
#include <stdio.h>
#include <stdlib.h>

/**
 *print_rev - it just prints the alphabet
 *@s : eaofhezui
 *Description : /
 *Return: no return
 */

void print_rev(char *s)
{
	int count = 0;
	char temp;
	
	while (*s != '\0')
	{
		count++;
		s++;
	}
	while (count > 0)
	{
		temp = s[count];
		_putchar(temp);
		count--;
	}
	_putchar('\n');
}
